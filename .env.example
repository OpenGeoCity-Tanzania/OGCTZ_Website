# Database
DATABASE_URL=mariadb://mysql:password@localhost:3307/ogctzdb

# Flask
SECRET_KEY=change-me-to-a-random-secret-string

# YouTube API (optional)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Openinary image storage (optional)
# When these are set, image uploads from the admin panel go to your Openinary instance.
# Example: http://localhost:3000 or https://cloud.opengeocity.org
# NOTE: If you use the Openinary fullstack image, the API is mounted at /api,
# so set OPENINARY_URL to https://cloud.opengeocity.org/api.
# If Openinary returns the wrong domain for image URLs, set OPENINARY_PUBLIC_URL
# to the public delivery base (e.g. https://cloud.opengeocity.org).
OPENINARY_URL=https://cloud.opengeocity.org
OPENINARY_PUBLIC_URL=https://cloud.opengeocity.org
OPENINARY_API_KEY=your-openinary-api-key

# Comment moderation (optional)
# Comma-separated list of words that flag a comment for manual approval.
# When empty or unset, all comments are approved automatically.
COMMENT_MODERATION_WORDS=spam,scam,harassment
