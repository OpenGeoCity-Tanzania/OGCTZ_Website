# Database
DATABASE_URL=mariadb://mysql:password@localhost:3307/ogctzdb

# Flask
SECRET_KEY=change-me-to-a-random-secret-string

# YouTube API (optional)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MinIO / S3-compatible object storage (optional)
# When these are set, image uploads from the admin panel go to MinIO
# and the public URL is used by the blog and CMS.
MINIO_ENDPOINT=cloud.opengeocity.org
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=ogctz
MINIO_SECURE=true
# Set MINIO_PUBLIC=false if the bucket is private; the CMS will then proxy images through /media/*.
MINIO_PUBLIC=true
